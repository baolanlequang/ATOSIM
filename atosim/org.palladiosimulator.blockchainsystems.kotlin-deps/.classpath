<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="con" path="org.eclipse.jdt.launching.JRE_CONTAINER">
		<attributes>
			<attribute name="maven.pomderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="con" path="org.eclipse.pde.core.requiredPlugins"/>
	<classpathentry exported="true" kind="lib" path="lib/kotlin-stdlib-2.2.0.jar"/>
	<classpathentry exported="true" kind="lib" path="lib/kotlinx-serialization-core-jvm-1.9.0.jar"/>
	<classpathentry exported="true" kind="lib" path="lib/kotlinx-serialization-json-1.9.0.jar"/>
	<classpathentry exported="true" kind="lib" path="lib/kotlinx-serialization-json-jvm-1.9.0.jar"/>
	<classpathentry exported="true" kind="lib" path="lib/kotlinx-coroutines-core-1.10.2.jar"/>
	<classpathentry exported="true" kind="lib" path="lib/kotlinx-coroutines-core-jvm-1.10.2.jar"/>
	<classpathentry kind="con" path="org.eclipse.m2e.MAVEN2_CLASSPATH_CONTAINER">
		<attributes>
			<attribute name="maven.pomderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="output" path="target/classes"/>
</classpath>
