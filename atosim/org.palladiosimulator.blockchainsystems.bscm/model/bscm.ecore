  <eSubpackages name="attackmodel" nsURI="http://palladiosimulator.org/BlockchainSystemComponentModel/AttackModel/1.0"
      nsPrefix="attackmodel">
    <eClassifiers xsi:type="ecore:EClass" name="Attack" abstract="true" eSuperTypes="platform:/plugin/org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="type" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EString"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="requiredHashPower" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="dependsOnNetworkDelay"
          eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EBoolean"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="baselineSuccessProbability"
          eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="parameters" upperBound="-1"
          eType="#//attackmodel/AttackParameter" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="gamma" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble"
          defaultValueLiteral="0"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="AttackScenario" eSuperTypes="platform:/plugin/org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EReference" name="attack" lowerBound="1"
          eType="#//attackmodel/Attack" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="attackers" upperBound="-1"
          eType="#//attackmodel/AttackerNode" containment="true"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="blockchainSystem" lowerBound="1"
          eType="#//blockchainsystem/BlockchainSystem"/>
      <eStructuralFeatures xsi:type="ecore:EReference" name="result" eType="#//attackmodel/AttackResult"
          containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="AttackerNode" eSuperTypes="platform:/plugin/org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
      <eStructuralFeatures xsi:type="ecore:EAttribute" name="powerShare" eType="ecore:EDataType http://www.eclipse.org/emf/2002/Ecore#//EDouble"/>
