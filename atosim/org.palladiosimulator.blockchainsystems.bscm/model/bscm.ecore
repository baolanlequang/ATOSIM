      <eStructuralFeatures xsi:type="ecore:EReference" name="LinkAllocations" upperBound="-1"
          eType="#//linkallocation/LinkAllocation" containment="true"/>
    </eClassifiers>
    <eClassifiers xsi:type="ecore:EClass" name="LinkAllocation" eSuperTypes="platform:/plugin/org.palladiosimulator.pcm/model/pcm.ecore#//core/entity/Entity">
